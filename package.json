{
  "name": "biblioteca-pimentas-vii",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=20.12.0"
  },
  "scripts": {
    "dev": "concurrently -k -n client,server -c yellow,cyan \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite",
    "dev:server": "cross-env ALLOW_IN_MEMORY_DATABASE=true SEED_DEMO_DATA=false tsx watch server/index.ts",
    "admin:bootstrap": "tsx server/bootstrap-admin.ts",
    "db:migrate": "tsx server/migrate.ts",
    "prebuild": "node -e \"const fs=require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('dist-server', { recursive: true, force: true });\"",
    "typecheck": "tsc -b && tsc -p tsconfig.server.json --noEmit",
    "build:client": "tsc -b && vite build",
    "build:server": "tsup server/index.ts --format esm --platform node --out-dir dist-server --clean --sourcemap",
    "build": "npm run build:server && npm run build:client",
    "build:dev": "tsc -b && vite build --mode development",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "cross-env NODE_ENV=production PORT=4173 ALLOW_IN_MEMORY_DATABASE=true SEED_DEMO_DATA=false node dist-server/index.js",
    "start": "cross-env NODE_ENV=production PORT=3001 node dist-server/index.js",
    "start:test": "cross-env NODE_ENV=production PORT=4173 ALLOW_IN_MEMORY_DATABASE=true SEED_DEMO_DATA=true node dist-server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:full": "npm run build && playwright test",
    "video:aluno": "npm run build && node tools/record-student-guide.mjs",
    "docker:build": "docker build -t biblioteca-pimentas-vii .",
    "docker:run": "docker run --rm -p 3001:3001 -e NODE_ENV=production -e PORT=3001 -e DATABASE_URL=postgres://postgres:postgres@host.docker.internal:5432/biblioteca_pimentas_vii biblioteca-pimentas-vii"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
